# ── Supabase (producción) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Supabase Storage (para subida de archivos) ────────────
# URL de tu proyecto Supabase (sin barra al final)
SUPABASE_URL=https://[PROJECT].supabase.co
# Clave de servicio (service_role) — NO la anon key
SUPABASE_SERVICE_KEY=eyJ...tu_service_role_key...
# Nombre del bucket creado en Supabase Storage (debe ser público)
SUPABASE_BUCKET=lotesapp

# ── MySQL local (desarrollo) ───────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inmobiliaria_db

# ── App ────────────────────────────────────────────────────
SESSION_SECRET=LotesAppClaveSecreta2024XYZ
NODE_ENV=production
PORT=3000
